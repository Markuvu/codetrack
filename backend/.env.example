PORT=3000

# Optional but recommended: free API key from https://clist.by/api/v4/doc/
# Without these, /api/contests falls back to Codeforces contests only.
CLIST_USERNAME=
CLIST_API_KEY=

# ---------------------------------------------------------------------------
# PostgreSQL - required for accounts, handle sync and CodeChef import.
# Local dev: `docker compose up -d db` then run `npm run migrate`.
# Production: point at your managed Postgres (append ?sslmode=require).
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://codetrack:codetrack@localhost:5432/codetrack

# Required when DATABASE_URL is set. Random 32+ char secret used to sign
# access tokens. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Access tokens are short-lived JWTs; refresh tokens rotate on every use.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# bcrypt work factor for password hashing (12 is a sensible production value).
BCRYPT_ROUNDS=12

# Comma-separated browser origins allowed by CORS. Leave empty for local
# development (allows all); ALWAYS set this in production, e.g.
# CORS_ORIGINS=https://app.codetrack.example
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# CodeChef service session - used ONLY to fetch the source code of the
# signed-in user's own CodeChef submissions. Create a dedicated CodeChef
# account, sign in with a browser, and copy the request Cookie header and
# the x-csrf-token value here (or better: into your secret manager).
# Leave empty to import submission metadata only (no source code).
# NEVER commit real values to Git.
# ---------------------------------------------------------------------------
CODECHEF_SESSION_COOKIES=
CODECHEF_CSRF_TOKEN=

# Politeness controls for the CodeChef import (defaults shown).
CODECHEF_FETCH_THROTTLE_MS=2500
CODECHEF_FETCH_TIMEOUT_MS=15000
CODECHEF_IMPORT_MAX_PAGES=10
CODECHEF_MAX_SOURCE_FETCHES_PER_RUN=40
